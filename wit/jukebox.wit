package jukebox:cartridge@0.3.0;

interface types {
  /// Interleaved L/R samples. Length is always 2 * num-frames.
  ///
  /// Interleaved stereo (not mono, not planar) because host audio APIs
  /// (cpal default-output, CoreAudio, WASAPI shared) expect interleaved
  /// frames, so we avoid a deinterleave on the hot path; mono would force
  /// every cartridge to widen its own stereo; planar (two lists) doubles the
  /// boundary-call count and canonical-ABI metadata for no gain.
  type audio-block = list<f32>;

  record loop-point {
    start-frame: u64,
    end-frame: u64, // exclusive
  }

  record metadata {
    title: string,
    artist: string,
    /// Total length the cartridge intends to play. 0 = infinite/generative.
    duration-frames: u64,
    /// Sample rate the cartridge was authored at. The host refuses to load if
    /// this disagrees with the device sample rate (v1: no resampling).
    sample-rate: u32,
    /// Optional loop region. If present, the host loops here.
    loop-point: option<loop-point>,
    /// Cartridge-controlled cover art. PNG bytes, recommended <= 16 KiB.
    cover-art: option<list<u8>>,
    /// Freeform tags for playlists. Keep small.
    tags: list<string>,
  }
}

/// Host-provided DSP. Optional: a self-contained cartridge may implement all
/// DSP inline and import nothing. Host imports earn their keep for *stateful*
/// effects — filter/reverb/delay/shaper state lives host-side (native, SIMD-able,
/// upgradeable), the cartridge holds an opaque handle.
interface dsp {
  use types.{audio-block};

  /// Stateless block generators. The caller owns phase/seed; the host returns
  /// the advanced value as the second tuple element, so one host node can drive
  /// many cartridge "voices" without the host tracking instance identity.
  osc-sine: func(freq-hz: f32, phase: f32, num-frames: u32, sample-rate: u32) -> tuple<audio-block, f32>;
  osc-saw: func(freq-hz: f32, phase: f32, num-frames: u32, sample-rate: u32) -> tuple<audio-block, f32>; // PolyBLEP
  osc-square: func(freq-hz: f32, phase: f32, pw: f32, num-frames: u32, sample-rate: u32) -> tuple<audio-block, f32>; // PolyBLEP
  osc-triangle: func(freq-hz: f32, phase: f32, num-frames: u32, sample-rate: u32) -> tuple<audio-block, f32>;
  osc-noise: func(seed: u64, num-frames: u32) -> tuple<audio-block, u64>;

  /// State-variable filter: lowpass/highpass/bandpass from one structure.
  resource biquad-svf {
    constructor(sample-rate: u32);
    set-params: func(cutoff-hz: f32, q: f32);
    /// Returns (lp, hp, bp).
    process: func(input: audio-block) -> tuple<audio-block, audio-block, audio-block>;
    reset: func();
  }

  /// Freeverb-style stereo reverb.
  resource reverb {
    constructor(sample-rate: u32);
    set-params: func(room-size: f32, damping: f32, wet: f32);
    process: func(input-l: audio-block, input-r: audio-block) -> tuple<audio-block, audio-block>;
  }

  /// Feedback delay line.
  resource delay {
    constructor(sample-rate: u32, max-seconds: f32);
    set-params: func(time-seconds: f32, feedback: f32, mix: f32);
    process: func(input: audio-block) -> audio-block;
  }

  enum shape-kind {
    soft-tanh,
    asym-tanh,
    hard-clip,
    cubic,
    wavefold,
  }

  /// Oversampled, anti-aliased waveshaper with built-in tightening EQ. This is
  /// the metalcore chug crunch: oversample around the nonlinearity so the
  /// harmonics it manufactures don't fold back as digital fizz.
  resource waveshaper {
    /// `oversample` must be 1, 2, or 4. 1 = no oversampling (aliases — for
    /// deliberately lo-fi tones only).
    constructor(sample-rate: u32, oversample: u8);
    set-shape: func(shape: shape-kind, drive: f32, bias: f32);
    /// Tightening EQ around the nonlinearity. 0 disables either filter.
    set-tone: func(pre-hp-hz: f32, post-lp-hz: f32);
    process: func(input: audio-block) -> audio-block;
    reset: func();
  }
}

/// Sample playback (v2). The host owns sample PCM and the playback voices
/// (native interpolation/resampling); the cartridge triggers notes. Samples
/// come from the host library (~/.jukebox/samples/<name>.wav — your real DI
/// guitars/drums) or from PCM the cartridge hands over. This is the only path
/// to literal recorded timbre; pure synthesis caps out at synthcore.
interface sampler {
  use types.{audio-block};

  /// A loaded sample owned by the host (mono, at the device sample rate).
  resource sample {
    /// Load `~/.jukebox/samples/<name>.wav`, downmixed to mono and resampled to
    /// the device rate. None if missing or unreadable.
    from-library: static func(name: string) -> option<sample>;
    /// Register cartridge-provided mono PCM (already at the device rate).
    from-pcm: static func(pcm: list<f32>) -> sample;
    frame-count: func() -> u64;
  }

  /// A sample-playback voice: plays one sample at a time, pitch-shifted by
  /// resampling. Hold several for polyphony.
  resource sample-voice {
    constructor();
    /// (Re)trigger `sample` at `speed` (1.0 = as recorded, 2.0 = octave up via
    /// faster playback) and linear `gain`, from the start.
    trigger: func(sample: borrow<sample>, speed: f32, gain: f32);
    /// Loop between two frames of the sample (in the sample's own frames).
    set-loop: func(enabled: bool, start-frame: u64, end-frame: u64);
    /// Render the next mono block; silence once finished (unless looping).
    render: func(num-frames: u32) -> audio-block;
    is-active: func() -> bool;
    stop: func();
  }
}

interface log {
  log: func(msg: string);
}

interface player {
  use types.{audio-block, metadata};

  /// Called once after instantiation. Receives the actual device sample rate.
  /// Returning an error string terminates loading.
  init: func(sample-rate: u32) -> result<_, string>;

  /// Render `num-frames` of audio starting at absolute frame `start-frame`.
  /// Output length MUST be 2 * num-frames (interleaved L/R).
  /// MUST be sync. MUST NOT block. Called at audio rate from a worker thread.
  render: func(start-frame: u64, num-frames: u32) -> audio-block;

  /// Snap internal state to a given frame. Used by host UI seeks.
  seek: func(frame: u64);

  /// Reset all internal state. Called on cartridge reload / loop.
  reset: func();

  /// Tells the host "I'm done; you can stop calling render()."
  is-finished: func() -> bool;

  get-metadata: func() -> metadata;
}

/// v0.2 world: a reactor that exports `player` and may import host `dsp` and
/// `log`. Imports are optional — a cartridge that calls neither still loads
/// (unused imports are tree-shaken out of the component).
world cartridge {
  import dsp;
  import sampler;
  import log;
  export player;
}
